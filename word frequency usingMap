import java.util.*;

public class Main {
    public static void main(String[] args) {
        String str = "java is easy java is powerful";

        HashMap<String, Integer> map = new HashMap<>();

        for (String word : str.split(" ")) {
            map.put(word, map.getOrDefault(word, 0) + 1);
        }

        System.out.println(map);
    }
}
