import java.util.*;
public class Main{
    public static void main(String[]args){
         Scanner sc = new Scanner(System.in);
         System.out.print("Enter size:");


        int n = sc.nextInt();
        int[] a = new int[n];

        for(int i = 0; i < n; i++) {
            a[i] = sc.nextInt();
        }
        System.out.print("target:");
         int target = sc.nextInt();
         
         Arrays.sort(a);
         
         for(int i = 0; i < n; i++) {
    for(int j = i + 1; j < n; j++) {
        if(a[i] + a[j] == target) {
            System.out.println(a[i] + " " + a[j]);
        }
    }
}
