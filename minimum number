import java.util.*;
public class Main{
    public static void main(String args[]) {
        Scanner sc = new Scanner(System.in);
        int a = sc.nextInt();
        int[] s = new int[a];
        int min=15;
        for(int i=0;i<a;i++){
            s[i]=sc.nextInt();
            if(s[i]<min){
                min=s[i];
            }
        }
         System.out.print(min);
    }
}

